  "pride_metadata": {
    "project": {
      "accession": "PXD023147",
      "title": "Neuropeptides in Lineus longissimus larvae",
      "additionalAttributes": [],
      "projectDescription": "The goal of this project was to identify potential neuropeptides in extracts from larvae of the nemertean species Lineus longissimus.",
      "sampleProcessingProtocol": "Mixed larval stages were collected, rinsed with ultrapure water and dissolved in an extraction buffer (90% Methanol, 9% acetic acid, 1% distilled water). The mixture was ground and centrifuged. The supernatant was transferred, evaporated and dissolved in ultrapure water. Neuropeptide mixtures were reduced and alkylated. LC-MS analysis was performed on an EasyLC nano-UHPLC coupled with a Q Exactive HF mass spectrometer. Peptides were separated with an 87-min segmented gradient of 10-33-50-90% HPLC solvent B (80% acetonitrile in 0.1% formic acid) at a flow rate of 200 nl/min. The 7 most intense precursor ions were sequentially fragmented in each scan cycle using higher energy collisional dissociation (HCD) fragmentation. In all measurements, sequenced precursor masses were excluded from further selection for 30 s. The target values for MS/MS fragmentation were 10^5 charges and 3x106 charges for the MS scan. MS/MS on singly charged precursor ions was enabled.",
      "dataProcessingProtocol": "Data was analyzed by MaxQuant software version 1.5.2.8 with integrated Andromeda search engine. Data was mapped to Lineus longissimus transcriptome sequences (genbank: SRX1343823). No enzyme specificity was defined. The minimal peptide length was set to four amino acids. The initial precursor mass tolerance was set to 4.5 ppm, for fragment ions a mass tolerance of 20 ppm was used. Carbamidomethylation of cysteines was defined as fixed modification. A set of expected variable modifications was defined: pyroglutamate formation of N-terminal glutamine, oxidation of methionine, acetylation of the peptide N-terminus, amidation of the peptide C-terminus, and sulfation of tyrosine. False discovery rates were set to 1% at peptide, modification site, and protein group level, estimated by the target/decoy approach.",
      "projectTags": [],
      "keywords": [
        "Larva",
        "Neuropeptides",
        "Nemertea"
      ],
