  "pride_metadata": {
    "project": {
      "accession": "PXD033536",
      "title": "The pivotal and universal role of BGLT3 lncRNA in fetal globin gene expression",
      "additionalAttributes": [],
      "projectDescription": "A highly selective and non-genotoxic G9a inhibitor, RK-701 was discovered, which upregulated the mRNA level of \u03b3-globin but not \u03b2-globin both in human erythroid cells and in mice. Using RK-701, we examined the induction of the fetal (\u03b3-) globin protein in human erythroid cells; HUDEP-2 and human CD34+ bone marrow and peripheral blood cells.",
      "sampleProcessingProtocol": "Protein fraction was digested with trypsin/Lys-C mix in 50 mM ammonium bicarbonate.Resulting peptides were directly applied to LC-MS/MS system.",
