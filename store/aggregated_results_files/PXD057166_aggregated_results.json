    "project": {
      "accession": "PXD057166",
      "title": "Cleaved Ycf1p mass spectrometry analysis",
      "additionalAttributes": [],
      "projectDescription": "LC MS/MS analysis of site of Pep4-mediated cleavage of Ycf1p",
      "sampleProcessingProtocol": "Ycf1p, containing a 3xFLAG tag at the C terminus of the protein, was purified from a yeast strain containing Pep4 protease. The purified sample was subjected to SDS-PAGE, and the two gel bands were subjected to trypsin digestion.",
      "dataProcessingProtocol": "Tryptic peptides were subjected to LC MS/MS. Raw MS files were analyzed with Proteome Discoverer (v2.5.0.4.00) software using the S. cerevisiae database and the sequence of Ycf1p-3\u00d7FLAG protein.  The addition of a carbamidomethyl group on Cys was specified as a fixed modification, while deamidation of Asn and Gln, oxidation of Met, acetylation of the N terminus, and phosphorylation of Ser, Thr, or Tyr were set as variable modifications. Data was visualized using Scaffold (v5.3.3).",
      "projectTags": [],
      "keywords": [
