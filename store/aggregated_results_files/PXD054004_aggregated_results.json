  "pride_metadata": {
    "project": {
      "accession": "PXD054004",
      "title": "Bottom-up mapping of RSV nonstructural protein 1 (NS1) for HDX-MS data analysis",
      "additionalAttributes": [],
      "projectDescription": "LC-MS/MS analysis of pepsin-digested RSV-NS1 protein to identify peptides for HDX-MS data processing",
      "sampleProcessingProtocol": "hRSV NS1 was buffer exchanged into PBS buffer (pH 7.4). NS1 was diluted with PBS buffer in H2O for peptide mapping. The protein was denatured via a 2:3 dilution with 3 M urea (final pH 2.5) at 4 \u00baC. The sample was injected into a custom built LC valve setup to be digested on an in-house coupled and packed immobilized pepsin column , trapped and desalted on a ZORBAX Eclipse XDB C8 column (2.1 mm x 15 mm, Agilent) using water/0.1% trifluoroacetic acid,  analytically separated on a Hypersil Gold C18 column (2.1 mm x 50 mm, Thermo Fisher) using a gradient from 4 to 40% acetonitrile/0.1% formic acid, and eluted into a LTQ-FTICR mass spectrometer (Thermo Fisher) for MS/MS analysis (top 6). All valves, tubes, and columns (except for the pepsin column) were submerged in an ice-water bath to minimize back-exchange. Peptide mapping data were analyzed using Byos\u00ae (Protein Metrics Inc.).",
      "dataProcessingProtocol": "Peptide mapping data were analyzed using Byos\u00ae (Protein Metrics Inc.) with non-specific digestion.",
