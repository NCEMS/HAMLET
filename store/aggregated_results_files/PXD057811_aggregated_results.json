  "pride_metadata": {
    "project": {
      "accession": "PXD057811",
      "title": "ncRNA DUBR RAP-MS in HCT116 cells",
      "additionalAttributes": [],
      "projectDescription": "Non-coding RNAs (ncRNAs) are finely tuned cellular regulators important for human cell growth and cancer progression. DUBR (also known as linc00883) is a nuclear ncRNA first discovered in mice for its role in regulating myoblast differentiation through interactions with chromatin and DNA methyltransferases. High expression levels of this ncRNA are predictive of poor patient outcome in colon adenocarcinoma, suggesting that DUBR may be involved in controlling cancer growth. To elucidate its function, we used RAP-MS and RNA immunoprecipitation techniques which revealed its interaction with epigenetic maintenance proteins in the human colon cancer cell line HCT116. Further, ATAC-seq and RNA-seq were used to address its function in regulating the epigenome and transcriptome of HCT116 cells. Here we report that DUBR is a regulator of human colon cancer cell line HCT116 survival.",
      "sampleProcessingProtocol": "RAP-MS protocol was used to capture protiens bound to DUBR RNA in HCT116 cells along with snRNA U1 (used as positive control), luciferase mRNA (used as negative control) and Linc00909 (another ncRNA). Breifly. cell lysate from 50-200 M UV 254 nm crosslinked HCT116 cells was used for each DNA probe and results in the capture of ~100-300 ng of protein. Protein was digested with trypsin after removal from RNA/probe complexes and cleaned up using a detergent removal column and C18 zip tip.",
      "dataProcessingProtocol": "MaxQuant was used to analyze raw files for ncRNA DUBR, snRNA U1, and luciferase mRNA RAP-MS results together. Intensity-based absolute quantification (iBAQ) was performed on the identified peptides to quantify protein abundance.",
      "projectTags": [],
      "keywords": [
        "Dubr",
