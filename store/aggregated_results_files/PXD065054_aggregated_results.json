  "pride_metadata": {
    "project": {
      "accession": "PXD065054",
      "title": "NUSAP1 interactome in human breast cancer cells",
      "additionalAttributes": [],
      "projectDescription": "Immunoprecipitation of NUSAP1 followed by mass spectrometry analysis to identify NUSAP1 binding partners in human breast cancer cells.",
      "sampleProcessingProtocol": "MDA-MB-231 cells stably expressing Flag-NUSAP1, treated with MG132 for 6 hours before harvest, were lysed using NETN lysis buffer(150 mM NaCl, 1 mM EDTA, 10 mM Tris-HCl, pH 8.0, 0.5% NP-40, protease inhibitors, and phosphatase inhibitors). The supernatant was collected and incubated with anti-Flag magnetic beads (BioLinkedIn, L1103) at 4 \u00b0C for 2 hours. The putative NUSAP1-interacting proteins in the immunoprecipitates were fractionated by SDS-PAGE. Gels were stained with Coomassie and gel lanes were excised. Gel pieces were digested with trypsin and peptides extracted with 0.25% formic acid-50% acetonitrile and dried. Just before analysis the peptides were re-dissolved in 0.5% formic acid and analysed with Q ExactiveTM Plus (Thermo) system coupled online to the EASY-Nlc1000 UPLC system.",
      "dataProcessingProtocol": "The resulting MS/MS data were processed using Proteome Discoverer 1.3. Tandem mass spectra were searched against Homo Sapiens database (SwissProt, 20395 sequences). Trypsin/P was specified as the cleavage enzyme, allowing up to 2 missing cleavages. Mass error tolerance was set to 10 ppm for precursor ions and 0.02 Da for fragment ions. Carbamidomethyation on cysteine residues was specified as a fixed modification, and oxidation on methionine residues was specified as variable modification. Peptide confidence was set to high, and the peptide ion score threshold was set to > 20.",
