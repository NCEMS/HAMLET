  "pride_metadata": {
    "project": {
      "accession": "PXD044692",
      "title": "Yue OATP1B1 protein interaction dataset",
      "additionalAttributes": [],
      "projectDescription": "Bottom up proteomics analysis of human OATP1B1 interaction network.",
      "sampleProcessingProtocol": "Samples in 2X sample buffer were spiked with 1pmol bovine casein as an internal digestion control and were then reduced with 10 mM dithiolthreitol  for 20 min at 55C, alkylated with 25mM iodoacetamide for 45 min at room temperature and subjected to S-trap (Protifi) trypsin digestion using manufacturer recommended protocols. Digested peptides were lyophilized to dryness and resuspended in 12 uL of 0.2% formic acid/2% acetonitrile containing 25fmol/uL pre-digested yeast alcohol dehydrogenase (Waters MassPrep) as a technical control.  Each sample was subjected to chromatographic separation on a Waters MClass UPLC equipped with a  1.8 \u03bcm Acquity HSS T3 C18 75 \u03bcm \u00d7 250 mm column (Waters Corp.) with a 90-min linear gradient of 5 to 30% acetonitrile with 0.1% formic acid at a flow rate of 400 nanoliters/minute (nL/min) with a column temperature of 55C. Data collection on the Fusion Lumos mass spectrometer was performed for three difference compensation voltages (-40v, -60v, -80v). Within each CV, a data-dependent acquisition (DDA) mode of acquisition with a r=120,000 (@ m/z 200) full MS scan from m/z 375 \u2013 1500 with a target AGC value of 4e5 ions was performed. MS/MS scans with HCD settings of 30% were acquired in the linear ion trap in \u201crapid\u201d mode with a target AGC value of 1e4 and max fill time of 35 ms. The total cycle time for each CV was 0.66s, with total cycle times of 2 sec between like full MS scans. A 20s dynamic exclusion was employed to increase depth of coverage. The total analysis cycle time for each sample injection was approximately 2 hours.",
      "dataProcessingProtocol": "Raw LC-MS/MS data files were processed in Proteome Discoverer 3.0 (Thermo Scientific) and then submitted to independent Sequest database searches against a Human protein database containing both forward (20371 entries) and reverse entries of each protein.  Search tolerances were 2 ppm for precursor ions and 0.8 Da for product ions using trypsin specificity with up to two missed cleavages.  Carbamidomethylation (+57.0214 Da on C) was set as a fixed modification, whereas oxidation (+15.9949 Da on M) was considered a dynamic mass modifications. All searched spectra were imported into Scaffold (v5.3, Proteome Software) and scoring thresholds were set to achieve a peptide false discovery rate of 1% using the PeptideProphet algorithm",
      "projectTags": [],
      "keywords": [
        "Proteomics",
        "Ap-ms"
      ],
