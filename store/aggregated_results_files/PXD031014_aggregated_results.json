    "project": {
      "accession": "PXD031014",
      "title": "Human nasopharyngeal cancer cell HONE1 FOXP1 immunoprecipitates LC-MS",
      "additionalAttributes": [],
      "projectDescription": "Identification of peptides matching to LCK in FOXP1 immunoprecipitates from HONE1 cells by mass spectrometry",
      "sampleProcessingProtocol": "Purified protein complex eluates were concentrated using IP beads (Bimake), resolved by SDS-PAGE, and stained with Coomassie Brilliant Blue (Beyotime). Stained bands that differed from the control were excised, subjected to in-gel reduction, alkylated, and digested with trypsin (Gibco) at 37\u00baC overnight. The digested peptides were dried and resuspended in an MS-compatible buffer, and the mixture was analyzed using the LTQ Orbitrap Velos MS (Thermo Fisher) in combination with the UltiMate RSLC Nano LC system (Dionex).",
      "dataProcessingProtocol": "The Proteome Discoverer 1.4 software (Thermo Fisher) was used to identify the protein, and the files were imported and used to explore the UniProtKB/Swiss-Prot database. The mass tolerances of precursors and fragments were set to 10 ppm and 0.8 Da, respectively. Data on the peptides with a false discovery rate of < 1% (q < 0.01) were discarded.",
      "projectTags": [],
      "keywords": [
        "Human",
