  "pride_metadata": {
    "project": {
      "accession": "PXD021365",
      "title": "Analysis of Gcn20 pullout samples by mass spectrometry",
      "additionalAttributes": [],
      "projectDescription": "Mass spectrometric analysis of Gcn20 pullout samples.",
      "sampleProcessingProtocol": "Gel band was destained in 1:1 acetonitrile (ACN):100 mM ammonium bicarbonate (ABC) with vortexing, reduced with 10 mM dithiothreitol at 56oC and alkylated with 50 mM chloroacetamide in the dark. Protein digestion was carried out overnight with 10 ng/\u00b5l of dimethylated porcine trypsin (Sigma Aldrich) in 100 mM ABC at 37oC. Peptides were extracted from the gel matrix using bath sonication, followed by 30 min vortexing in 2 volumes of 1:2 5% formic acid (FA): ACN. The organic phase was evaporated in a vacuum-centrifuge, after which the peptides were desalted on in-house made C18 (3M) solid phase extraction tips. Purified peptides were reconstituted in 0.5% trifluoroacetic acid.",
      "dataProcessingProtocol": "MS raw files were processed with the MaxQuant software package (version 1.6.1.0) (PMID: 27809316). Methionine oxidation, protein N-terminal acetylation were set as potential variable modifications, while cysteine carbamidomethylation was defined as a fixed modification. Identification was performed against the UniProt (www.uniprot.org) Saccharomyces cerevisiae (strain ATCC 204508 / S288c) reference proteome database using the tryptic digestion rule. Only identifications with at least 1 peptide \u2265 7 amino acids long (with up to 2 missed cleavages) were accepted. Intensity-based absolute quantification (iBAQ) (PMID: 21593866) feature of MaxQuant was enabled. This normalizes protein intensities by the number of theoretically observable peptides and enables rough intra-sample estimation of protein abundance. Peptide-spectrum match, peptide and protein false discovery rate was kept below 1% using a target-decoy approach (PMID: 17327847). All other parameters were default.",
      "projectTags": [],
      "keywords": [
        "Gcn2",
        "Gcn20",
        "Ribosome",
        "Gcn1",
        "Translation"
      ],
