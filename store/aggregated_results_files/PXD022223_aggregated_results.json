  "pride_metadata": {
    "project": {
      "accession": "PXD022223",
      "title": "Proteome analysis of Different types of Human teeth",
      "additionalAttributes": [],
      "projectDescription": "We have isolated protein extracts from four major types of human teeth i.e. Molar,Premolar,Incisor and Canine through deminralization process. Within these four extrcats, we identified and quatitated differential protein abundance through MS based approach.",
      "sampleProcessingProtocol": "Proteins were isolated from a pooled teeth by crushing the identical pool types in presence of liquid nitrogen in a pestle and motar. These powdered extract was further demineralized by EDTA and Nacl. Thenafter, standard MS tripsin digestion and nano-LC runs were performed on C-18 coloumn. Finally MS spectra were obtained from Thermo Fisher Q-Extractive equiped with nanoelectronspray.",
      "dataProcessingProtocol": "Generated raw files were analyzed using Proteome Discoverer(2.2) against Uniprot Human Reference. Sequest search was done and protein false discovery rate was set to 0.01FDR.",
      "projectTags": [],
      "keywords": [
        "Mass spectrometry",
        "Tooth proteome",
        "Protein protein interactions",
        "Teeth composition"
      ],
