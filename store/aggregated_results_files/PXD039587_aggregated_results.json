  "pride_metadata": {
    "project": {
      "accession": "PXD039587",
      "title": "neonatal rat cardiomyocytes LC-MS/MS",
      "additionalAttributes": [],
      "projectDescription": "NRCMs were treated with ISO (10 \u03bcM) in the presence or absence of FGF18 (50 ng/ml) for 48 h. Protein bands at ~60 kDa were excised from the SDS-PAGE gels for LC-MS/MS analysis",
      "sampleProcessingProtocol": "Protein bands at ~60 kDa were excised from the SDS-PAGE gels, reduced with 10 mM of DTT and alkylated with 55 mM iodoacetamide, and then digested with Sequence Grade Modified Trypsin (Promega, Madison, WI) in ammonium bicarbonate buffer at 37\u2103 overnight. The digestion products were extracted twice with 0.1% trifluoroacetic acid, 50% acetonitrile and 1.0% trifluoroacetic acid, respectively. The extracted mixture was dried by SpeedVac and dissolved in 10 \u03bcL of 0.1% trifluoroacetic acid for LC-MS/MS analysis",
      "dataProcessingProtocol": "The gradient consisted of 5~35% (v/v) acrtonitrile in 0.1% (v/v) formic acid at a flow rate of 200 nL/min for 10 min, 35~100% (v/v) acrtonitrile in 0.1% (v/v) formic acid at a flow rate of 200 nL/min for 2 min and 100% acrtonitrile in 0.1% formic acid at a flow rate of 200 nL/min for 8 min. The eluted peptides were ionized and introduced into a Thermo Fisher LTQ Velos Pro mass spectrometer (Thermo Fisher Scientific, Bremen, Germany) using a Proxeon nanoelectrospray ion source. Survey full-scan MS spectra (from m/z 200~1800) were acquired. A full mass spectrum (m/z 200~1800) was followed by fragmentation of the ten most abundant peaks, using 35% of the normalized collision energy for obtaining MS/MS spectra. All peptide assignments were verified by manual inspection. Data analyzed by Thermo Proteome Discoverer 1.4.1.14 software.",
      "projectTags": [],
      "keywords": [
        "Nrcms iso"
      ],
