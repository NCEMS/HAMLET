  "pride_metadata": {
    "project": {
      "accession": "PXD064237",
      "title": "Protein identification of recombinant SLFN11 and SLFN14",
      "additionalAttributes": [],
      "projectDescription": "The Schlafen (SLFN) family of nucleic acid binding proteins play an important role in gene regulation. In response to environmental stress, many SLFN members are activated for RNA cleavage and translational regulation. To characterize the RNA cleavage activity of this protein family, we produced recombinant human SLFN11 and SLFN14 protein. We utilized mass spectrometry for protein identification to confirm the identity of our recombinant SLFN protein samples.",
      "sampleProcessingProtocol": "The isolated proteins (SLFN11 and SLFN14) from HEK293 cells were resolved onto SDS-PAGE gel (NuPAGE 10% Bis-Tris Gel, Invitrogen). The protein band of interest at around 100kDa was excised from the gel and subjected to in-gel digestion using trypsin and LysC protease mix. The extracted peptides were dried in a speed vac and dissolved in 5% methanol containing 0.1% formic acid buffer. The peptide samples were analyzed using a nanoLC1200 system coupled to Orbitrap Fusion Lumos mass spectrometer (Thermo Scientific, San Jose, CA). The MS data was acquired for a 110min total run time at 200nl/min using the data dependent mode. The full MS scan was acquired in Orbitrap in the range of 300-1400m/z at 120,000 resolution followed by MS2 in Ion Trap (HCD 28% collision energy) with 15sec dynamic exclusion time.",
      "dataProcessingProtocol": "The MS raw data was searched in Proteome Discoverer 2.0 software (Thermo Scientific, San Jose, CA) with Mascot algorithm (v2.5) against human NCBI refseq protein database (updated 2021_12_23). The precursor ion tolerance and product ion tolerance were set to 20ppm and 0.5Da respectively and a maximum of two missed cleavage allowed. Following variable modification were allowed: Oxidation on Methionine, protein N-terminal Acetylation, Carbamidomethylation on cysteine, GlyGly remanent on lysine,  Acetylation on lysine, Methylation on arginine and Phosphorylation on serine, threonine and tyrosine was allowed.. The peptides identified from mascot result file were validated in Percolator with 5% false discover rate (FDR). The peptide spectra for expected PTM shifts were manually validated for correct assignment.",
      "projectTags": [],
      "keywords": [
        "Schlafen",
        "Slfn11",
        "Slfn14"
      ],
