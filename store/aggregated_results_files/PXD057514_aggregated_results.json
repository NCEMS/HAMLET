  "pride_metadata": {
    "project": {
      "accession": "PXD057514",
      "title": "Proteomics analysis of lysine methylated proteins from Leishmania donovani strain 1S: wild type and set mutants",
      "additionalAttributes": [],
      "projectDescription": "This study was performed with the goal of understanding the roles of Leishmania donovani SET7 and SET29 proteins. Using homologous recombination, set7 and set29 genes were knocked out, thereby creating set7 and set29 mutant parasites. Whole cell extracts were isolated from wild type parasites, set7 mutant parasites and set29 mutant parasites, followed by immunoprecipitation of lysine methylated proteins using anti-methyllysine antibody. The immunoprecipitated proteins were identified by LC-MS analysis.",
      "sampleProcessingProtocol": "Proteins with methylated lysine residues were enriched by immunoprecipitation using anti-methyllysine antibody. Whole cell extracts were prepared from 1x109 promastigotes using mammalian protein extraction reagent (MPER; Invitrogen) with protease inhibitors, followed by immunoprecipitation using anti-methyllysine antibodies. The IP eluates were heated at 95\u00b0C for 10 minutes with intermittent tap mixing and loaded on 10 % SDS gel. The gel pieces carrying the stacked proteins were carefully excised out using a sterile surgical blade, just after the proteins entered the resolving gel. For processing, the gel piece was further chopped into smaller pieces, followed by an in-gel destaining using ammonium bicarbonate (25 mM)/ Acetonitrile (50 %), after which they were subjected to in-gel reduction using DTT (10 mM) in ammonium bicarbonate (25 mM). In-gel alkylation was carried out using iodoacetamide (50 mM) in ammonium bicarbonate (25 mM). The gel pieces were shrunk by using 100 % acetonitrile, followed by treatment with 2 \u00b5g of trypsin at 37\u00b0C for 16 hours. The peptides were extracted by treating the gel pieces with 80 % acetonitrile solution containing 0.1 % formic acid. The extraction was repeated thrice. The extracted peptides were dried using a vacuum concentrator and cleaned up using Pierce\u2122 Peptide Desalting Spin Columns (Thermo Fisher Scientific). The samples were re-suspended in appropriate volume of 2% acetonitrile solution with 0.1% formic acid, followed by LC-MS analysis using the Thermo Scientific Q-Exactive Orbitrap system coupled with EASY-nLC 1200 (Thermo Fisher Scientific). The peptides were loaded on the EASY-Spray PepMap RSLC C18 column, (2\u00b5m, 75\u00b5m x 50cm, 100 \u00c5 pore size, Thermo Scientific) and separated using a gradient of 5% - 45% (Solvent A: 2% acetonitrile - 0.1% formic acid; Solvent B: 80% acetonitrile - 0.1% formic acid) over 120 minutes. For MS1 a resolution of 70000 over the scan range of 350 to 2000m/z used with AGC of 3.0e6, and maximum ion transfer time of 50 ms. For MS2 the resolution of 17500 was used with AGC of 1.0e5, and maximum ion transfer time of 120 ms. The unit for normalized collision energy was set at 27. Dynamic exclusion was applied with a loop count of 10 and dynamic exclusion time of 50 s.",
      "dataProcessingProtocol": "The raw data was analyzed using Proteome Discoverer version 2.4.1.15 software. Peptide sequences were identified using the L. donovani proteome library available in TriTrypDB (TriTrpDB-68_LdonovaniBPK282A1_AnnotatedProteins.fasta).",
      "projectTags": [],
