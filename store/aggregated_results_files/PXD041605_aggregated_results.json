  "pride_metadata": {
    "project": {
      "accession": "PXD041605",
      "title": "OGA-mediated protein glycosylation regulates pluripotency states in human embryonic stem cells",
      "additionalAttributes": [],
      "projectDescription": "In our previous study, we uncovered that OGA significantly elevated in na\u00efve hESC. Therefore, we sought to investigate the effects of O-GlcNAc on hESC and the interconvert of both pluripotent states. Depletion of OGA, which results in global O-GlcNAcylation increased, would impair na\u00efve hESC pluripotency but can promote na\u00efve to primed hESC transition. In addition, we obtained the profiles of O-GlcNAcylated proteins in H9 primed hESC and H9-PXGL hESC via MS based-quantitative proteomics.",
      "sampleProcessingProtocol": "Samples were dispersed into 50mM NH4HCO3 (pH 8.0), followed by reduction with 10mM DTT at 56\u2009\u00b0C for 1h, and cysteine alkylation with 20mM IAA at RT for 45min in the dark. The denatured proteins were digested overnight at 37 \u00b0C by trypsin (at a 1:50 ratio of enzyme to protein). Reactions were quenched by adding TFA to a final concentration of 0.1%. The digested peptides were desalted by reverse phase C18 tips and freeze dried. Next, the peptides were resuspended in 100mM TEAB buffer (pH 8.5) for isotopic dimethyl labelling.",
      "dataProcessingProtocol": "MS raw files were analyzed using MaxQuant version 1.6.17.0 against the UniPort Human database (downloaded on March 2021, counting 20386 entries). The false discovery rate (FDR) was set as \u22640.01 at the level of peptide spectrum matching (PSM) and protein assembly, with a minimal peptide length of seven amino acids. The protease was set as trypsin/P with a maximum of two missed cleavages. In addition to the default settings, a labelling scheme based on multiplicity two was set as follows: DimethLys0/DimethNter0 (light label); DimethLys4/DimethNter4 (heavy label).",
      "projectTags": [],
      "keywords": [
        "Human embryonic stem cells\uff0coga\uff0co-glcnac"
      ],
