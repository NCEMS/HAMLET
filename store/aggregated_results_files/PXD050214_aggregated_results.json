  "pride_metadata": {
    "project": {
      "accession": "PXD050214",
      "title": "Carrier protein-enabled host cell proteome analysis (CP-HCP) with integrated isobaric tag interference filtering",
      "additionalAttributes": [],
      "projectDescription": "We have created a CP-HCP method to characterise the carrier proteome of a host cell expression system producing recombinant protein biotherapeutic, which can be compared with the testing sample mixture containing trace amounts of host cell proteins against high-background recombinant protein and also a recombinant protein peptide characterisation channel, using TMT labelling.",
      "sampleProcessingProtocol": "We set up a carrier proteome channel containing in ug E coli peptides digested and labelled with TMT, enchance by a BOOST TMT label. We labelled our sample channel with ng of E coli peptides against ug of high-background BSA (our mock recombinant protein) using another TMT label. We set up an interference detection channel of BSA peptides in ug, containing BSA peptides labelled with another TMT label. TMT labelling was done after tryptic digestion.",
      "dataProcessingProtocol": "Raw files were converted to mzmL and processed into PSMs using FragPipe. PSMs were statistically analysed using RStudio. Any PSMs falsely identified as E coli in the sample channel by comparing with the interference detection channel were removed computationally to reveal true HCP PSMs.",
      "projectTags": [],
      "keywords": [
        "Psms",
        "Host cell proteins",
        "Ms3",
        "Tmt",
        "Carrier proteome",
        "Multiplexed proteomics",
        "Lc-ms",
