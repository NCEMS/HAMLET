  "pride_metadata": {
    "project": {
      "accession": "PXD047509",
      "title": "The chromatin factors SET-26 and HCF-1 oppose the histone deacetylase HDA-1 in longevity and gene regulation in C. elegans",
      "additionalAttributes": [],
      "projectDescription": "In this study, a GFP-tagged version of the protein HCF-1 was immuno-precipitated from C. elegans lysates of the strain IU171 and co-purifying proteins were identified by LC-MS/MS. As a negative control, the same immuno-precipitation was conducted from wild-type (strain N2) worms that did not carry a HCF-1::GFP transgene.",
      "sampleProcessingProtocol": "The respective C. elegans strains were grown to scale, harvested, washed, and lysed, as described in (Riedel et al., NCB 2013; Pubmed ID: 23604319; DOI: 10.1038/ncb2720). The protein of interest was immunoprecipitated using an anti-GFP antibody (3E6), washed, and eluted using glycin, as described in (Riedel et al., NCB 2013; Pubmed ID: 23604319; DOI: 10.1038/ncb2720). The eluate was then trypsin-digested and resulting peptides analysed by LC-MSMS, as described in (Riedel et al., NCB 2013; Pubmed ID: 23604319; DOI: 10.1038/ncb2720).",
      "dataProcessingProtocol": "RAW data from the mass spectrometer were searched using SEQUEST and a database of the C. elegans proteome, as described in (Riedel et al., NCB 2013; Pubmed ID: 23604319; DOI: 10.1038/ncb2720).",
