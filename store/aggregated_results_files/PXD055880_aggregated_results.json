  "pride_metadata": {
    "project": {
      "accession": "PXD055880",
      "title": "Human A4GNT+THP-1 cell membrane proteins bingding with TFF2 by LC-MS",
      "additionalAttributes": [],
      "projectDescription": "NC or A4GNT+THP-1 cells were incubated with TFF2-3xFlag protein overnight at 4\u2103, then, co-immunoprecipitation with flag beads. Elute fluid was seperated on SDS-PAGE,and Silver Staining were used to screen the differential protein bands , then,the differential protein band was excised and further identified with LC-MS.",
      "sampleProcessingProtocol": "Transfer the protein strips into a 1.5 mL centrifuge tube and rinse the strips twice with ultrapure water. Then add the decolorizing solution to the centrifuge tube for 30min.Then, The strips were treated with enzymatic hydrolysis, protein desalination, then, separated by capillary high performance liquid chromatography and analyzed by Q-Exactive mass spectrometry (Thermo Scientific).",
      "dataProcessingProtocol": "MS/MS spectra were searched using the MaxQuant against the Uniprot Mus Musculus  database. Search database specific parameters are set as follows: Fixed modifications\uff1aCarbamidomethyl(C); Variable modification\uff1aOxidation\uff08M\uff09and Acetyl\uff08Protein N-term\uff09; digestion: trypsin; First search peptide tolerance: 20ppm; Main search peptide tolerance: 4.5 ppm; Max Missed: 2.",
      "projectTags": [],
