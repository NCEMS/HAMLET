  "pride_metadata": {
    "project": {
      "accession": "PXD017655",
      "title": "GPI-glycan structures of human Prion from knock-in mice_LC-MSMS",
      "additionalAttributes": [],
      "projectDescription": "To determine glycosylphosphatidylinositol (GPI) structures of human prion proteins isolated from knock-in mice those express human prion protein instead of mouse one.",
      "sampleProcessingProtocol": "We used knock-in mouse termed Ki-Hu129M/M which expresses human prion protein with the 129M/M genotype. We affinity purified human prion from knock-in mouse brains by anti-prion antibody after phosphatidylinositol-specific phospholipase C treatment to remove GPI lipid portion. Then, we treated the purified sample with peptide-N-glycosidase F to remove the N-glycans. Sample was separated by SDS-PAGE and the gel corresponding to prion was excised. Excised gel was reduced with 10 mM DTT and alkylated with 55 mM iodoacetamide followed by the digestion with trypsin. The resulted peptide sample was purified with Nu-Tip polyHydroxyethylA (HILIC) (purchased from glygen) according to the manufacture\u2019s protocol. Purified peptides were dried and resuspended in 0.1% formic acid, generating a measurement sample. Sample was separated by forward-phase HPLC with nanoLC using HILIC column (Capillary EX-Nano Inert Sustain Amide 3 \u00b5m 0.1 x 150 mm from GL Science). Data was obtained by LTQ Orbitrap Velos mass spectrometry.",
      "dataProcessingProtocol": "Xcalibur Software was used for analysis of mass data. In the MS/MS profiles, those that contain characteristic fragments derived from GPI anchors, such as fragment ions of m/z 422+ and 477+, were selected, and fragments in the selected profiles were assigned to determine the GPI structures.",
      "projectTags": [],
      "keywords": [
        "Gpi",
        "Prion",
        "Gpi side-chain",
        "Brain",
        "Knock-in mouse",
        "Human"
