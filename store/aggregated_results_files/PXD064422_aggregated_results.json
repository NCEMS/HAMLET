  "pride_metadata": {
    "project": {
      "accession": "PXD064422",
      "title": "Mass Spectrometry of Escherichia coli expressing ParA from F' plasmid or weak IPTG inducible promoter (pDSW210 vector)",
      "additionalAttributes": [],
      "projectDescription": "Comparisonof ParA levels in E. coli carrying mini-F plasmids (ParA expressed from the native ParA promoter) with ParA-GFP levels expressed froma weak Ptrc promoter in pDSW210 vector.",
      "sampleProcessingProtocol": "E. coli strains carrying mini-F plasmid (where ParA is expressed from its native promoter PparA) or pDSW210-ParA-GFP (where ParA-GFP is expressed from the weakened Ptrc  promoter) were grown overnight. A 1:100 dilution was then made into fresh LB medium and grown until the cultures reached an OD600 of 0.2. While 200 \u03bcM IPTG was used to induce the expression of ParA-GFP fusion protein in the cultures, expression of ParA  in mini-F plasmids was regulated by its native promoter (PparA). Cells were lysed using 8M urea as a denaturant in the lysis buffer (8M Urea, 100 mM NaH2PO3, Tris-HCl pH 8.0) and equal amounts of total protein was separated using 10% SDS-PAGE. Gels pieces containing the protein bands were further processed for a label-free mass spectrometric protein quantification at the Taplin Mass Spectrometry Facility (https://taplin.hms.harvard.edu/). Proteins were subjected to LC-MS using Thermo Scientific Fusion LumosTM.",
      "dataProcessingProtocol": "SEQUEST software was used to analyse the peptides using a reference sequence for ParA (UniProtID: P62556) and GFP.",
      "projectTags": [],
      "keywords": [
        "F' plasmid",
        "Escherichia coli",
        "Para"
      ],
