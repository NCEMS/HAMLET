  "pride_metadata": {
    "project": {
      "accession": "PXD071359",
      "title": "Production of recombinant human type III collagen in Physcomitrella",
      "additionalAttributes": [],
      "projectDescription": "We produced a 30 kDa His-tagged human collagen polypeptide in Physcomitrella moss plants.",
      "sampleProcessingProtocol": "Intracellular collagen was purified from 100 mg moss protonemavia His-Trap Spin columns. 10\u00b5g were were separated via SDS-PAGE and the band corresponding to the expected mass of the collagen polypeptide was cut reduced and alkylated and digested with trypsin over night. Resulting peptides were desalted using C18 Stage Tips as described in Bohlender et al., (2020; doi: 10.3389/fpls.2020.610032). Peptides were analysed on a Orbitrap XL mass spectrometer online coupled to an UltiMate 3000 RSLCnano HPLC system (Thermo Fisher Scientific) as described in Njenga et al. (2024; https://doi.org/10.1016/j.str.2024.09.019)",
      "dataProcessingProtocol": "The raw data were processed using Mascot Distiller V2.7.10, and a database search was conducted with the Mascot server V2.7 (Matrix Science, London, United Kingdom). Processed spectra were searched against a database containing all Physcomitrella protein models (V3.372; Lang et al. 2018; doi: 10.1111/tpj.13801), the sequence of the collagen polypeptide, and a database of known contaminants (269 entries), using a precursor mass tolerance of 8 ppm and a fragment mass tolerance of 0.6 Da",
      "projectTags": [],
      "keywords": [
        "Collagen",
        "Physcomitrella"
      ],
