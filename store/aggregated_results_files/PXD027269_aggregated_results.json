  "pride_metadata": {
    "project": {
      "accession": "PXD027269",
      "title": "Analysis of components of Buxuetongluo Pills by LC-MS/MS",
      "additionalAttributes": [],
      "projectDescription": "Buxue tongluo Pills(BTP) are a pill commonly used to treat osteonecrosis of the femoral head, but its composition and mechanism are unclear. As a result, we analyzed the components of BTP by LC-MS/MS.",
      "sampleProcessingProtocol": "The powder of BTP (10 g) was ultrasonically dissolved with 300 mL 75% ethanol and followed by concentrating to 100 mL using a rotary evaporator. Then, the supernatant was filtered by microporous membranes with a pore size of 0.22 \u03bcm. Then, the obtained 10 \u03bcL filtrates of BTP were analyzed by LC-MS/MS.",
      "dataProcessingProtocol": "By comparing the molecular weight, data of MS1 and MS2 with published articles, the composition of BTP was analyzed.",
      "projectTags": [],
      "keywords": [
        "Component",
        "Lc-ms/ms",
        "Buxuetongluo pills"
      ],
