    "project": {
      "accession": "PXD012660",
      "title": "LC-MS/MS proteomics analysis of Panc-1 EVs isolated using SEC",
      "additionalAttributes": [],
      "projectDescription": "LC-MS/MS proteomics analysis of Panc-1 EVs isolated using SEC",
      "sampleProcessingProtocol": "EVs were isolated by size exclusion chromatography. Samples were lyzed in 2% deoxycholate, 25mM Tris-HCl pH 7 and 2X HALT Proteins were reduced with TCEP, alkylated with iodoacetamide, digested overnight with trypsin Peptides were separated on a Ultimate 3000 UHPLC (C18 column) and analyzed on a Thermo Orbitrap Fusion Lumos Tribrid operated in data dependent acquisition mode.",
