  "pride_metadata": {
    "project": {
      "accession": "PXD061884",
      "title": "Derived Small Extracellular Vesicles",
      "additionalAttributes": [],
      "projectDescription": "Epithelial ovarian cancer (OvCa) remains a leading cause of mortality among gynecological cancers. The median age of diagnosis is 63 and there exists a strong correlation between advanced age, OvCa incidence and disease stage.  sEVs were analyzed using to LC-MS/MS analysis to identify and quantify sEV thier protein cargoes and were incubated with OvCa cells to evaluate their effect on pro-metastatic behaviors.",
      "sampleProcessingProtocol": "A final concentration of 1.2% of phosphoric acid was used to quench the alkylation reaction. Following manufacturer instructions, 100 mM TEAB was added to 90% methanol to form a protein suspension which was spun onto an S-Trap device and rinsed. Proteins retained on the S-Trap were digested using sequencing grade Lys-C/trypsin mixture at an enzyme-to-substrate ratio of 1:50 (w/w) in TEAB. Following digestion, peptides were eluted using 100 mM TEAB followed by 0.1% FA in water. The reaction was quenched with 10% FA. A third elution was performed using 50% acetonitrile (ACN) and 0.1% FA. ",
      "dataProcessingProtocol": "The search peptide mass tolerance was set to 10 ppm. Trypsin was set as the digestion enzyme with a maximum of two missed cleavages. Carbamidomethylation was set as a fixed modification, while oxidation (M), acetylation (protein N-term), deamidation (NQ), Phosphorylation (HCDR and STY), and Ubiquitination were set as variable modifications. ",
      "projectTags": [],
      "keywords": [
