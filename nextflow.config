nextflow.enable.dsl = 2

params {
  // Input modes: single PXD or CSV with multiple PXDs
  pxd    = null      // Single PXD to process
  pxd_csv = null     // CSV file with PXDs to process (column: PXD)
  num_pxds = null    // Limit number of PXDs from CSV (null = all)
  
  year   = '2021'
  month  = '09'
  day    = '01'

  central_mzml_dir   = "${baseDir}/spectral_files"
  outdir             = "${baseDir}/results"

  contaminants_fasta = "${baseDir}/assets/UniversalContaminats.fasta"
  taxid_list_file    = "${baseDir}/assets/taxid_lists/CommonPRIDEtaxids.txt"

  // Container-free pipeline: all tools run via conda environments
  sage_config       = "${baseDir}/assets/default_sage.config"
  
  // Search process parameters (applies to both DDA/SAGE and DIA/DIA-NN)
  run_search = false
  taxid = null  // Default taxid if no organism info found (null = skip search if no taxid determined)
  search_min_ptm_psms = 50  // Minimum PSMs required for a PTM to be included in closed search (prevents OOM)
  search_max_variable_mods = 3  // Maximum number of distinct residues with variable mods in closed search (prevents stack overflow)
  high_confidence_q_threshold = 0.01  // spectrum_q < this value counts as high-confidence PSM
  min_high_confidence_peptides = 10  // If fewer high-confidence PSMs than this, skip PTM-Shepherd and closed search
  
  // Acquisition type selection: AUTO (default, uses detected_params.json), DDA, or DIA
  acquisition_type = 'AUTO'
  
  // Auto-detection of acquisition type and labeling from runAssessor
  auto_detect = true
  
  // DIA-NN modifications (for DIA experiments)
  diann_modifications = [
    "UniMod:35,15.994915,M",      // Oxidation (M)
    "UniMod:1,42.010565,*n",      // Acetyl (N-term)
    "UniMod:4,57.021464,C"        // Carbamidomethyl (C) - fixed
  ]
  
  // LLM-based metadata extraction from publications
  run_llm_extraction = false
  run_agentic_metadata = false
  pride_database_path = "/THISPATHDOESNOTEXIST"
  llm_prompt_file = "${baseDir}/src/BaselinePrompt.txt"
  llm_workers = 1  // API calls per PXD (keep low to avoid rate limits)
  
  // Download options - aria2c for parallel downloads
  use_aria2c = true
  aria2c_threads = 4       // Reduced from 8 to decrease network load
  max_raw_files = 30  // null = download all files, or set to integer to limit
  
  // Resource throttling for large files (1.7-2.5 GB per file)
  max_parallel_pxds = 10   // Maximum number of PXDs to process in parallel (prevents download timeouts)
  download_timeout = '4h'  // Timeout for large file downloads + conversions
  
  // Organism identification parameters
  denovo_threshold = 80
  min_peptides_for_peptonizer = 5

  // Cascadia model path (stored in repo assets, must be downloaded separately due to size)
  cascadia_model_path = params.cascadia_model_path ?: "${baseDir}/assets/cascadia.ckpt"
  
  // Conda base path - where environments are installed
  // Defaults to local Miniconda; override with: nextflow run main.nf --conda_base /custom/path
  conda_base = params.conda_base ?: "${System.getenv('HOME')}/miniconda3"
  
  // Conda initialization command - necessary for HPC systems where conda isn't in PATH
  // Override with: nextflow run main.nf --conda_init "source /custom/conda.sh || true"
  conda_init = "source ${params.conda_base}/etc/profile.d/conda.sh || true"

  // Conda environments for denovo prediction and search (created by bash src/setup.sh).
  // These provide runtime dependencies (PyTorch, Lightning, etc.) only.
  // The actual code executed is src/casanovoBolt/ and src/cascadiaBolt/ (passed via --src_dir).
  cascadia_env_path = "${params.conda_base}/envs/cascadia_env"
  casanovo_env_path = "${params.conda_base}/envs/casanovo_env"
  meti_env_path = "${params.conda_base}/envs/meti_env"
  search_env_path = "${params.conda_base}/envs/search_env"
  
  // Peptonizer2000 host path (runs directly from this path, no containers)
  peptonizer2000_host_path = "${baseDir}/src/Peptonizer2000"
  
  // Optional: Peptonizer2000 singularity container (if set, overrides conda-based execution)
  peptonizer_container = null

  // Number of GPUs available for organism_id (de novo) tasks.
  // Controls both maxForks (concurrency throttle) and CUDA_VISIBLE_DEVICES assignment.
  // NOTE: The `accelerator` directive is only supported by SLURM/cloud executors, not local.
  // For local executor, GPU isolation is done manually via CUDA_VISIBLE_DEVICES in the script.
  num_gpus = 2
}

process {
  executor = 'local'
  shell    = ['/bin/bash', '-ue']
  
  // Enable better caching behavior
  cache = 'lenient'
  
  // Pass API keys from shell environment to all processes
  env = [
    LLM_API_KEY: System.getenv('LLM_API_KEY'),
    OPENAI_API_KEY: System.getenv('OPENAI_API_KEY') ?: System.getenv('LLM_API_KEY')
  ]
  
  // Default resource allocation
  cpus = 110
  memory = '1000 GB'
  
  // Process-specific resource management
  withName: fetch_pxd {
    cpus = 4
    memory = '10 GB'
    // Reduced parallelism to avoid network/PRIDE server saturation
    // Large files (1.7-2.5GB) need adequate bandwidth and time
    maxForks = 20
    time = '6h'  // Increased from 2h to allow for large downloads + conversion
    // FetchPXD.py uses exit code 42 to indicate "no usable RAW files".
    // In that case we ignore/skip the PXD. For other failures, retry up to
    // maxRetries and then ignore (don't kill the whole run for one PXD).
    errorStrategy = { task.exitStatus == 42 ? 'ignore' : (task.attempt <= 3 ? 'retry' : 'ignore') }
    maxRetries = 1
  }
  
  withName: organism_id {
    // accelerator directive is NOT supported by local executor — GPU assignment is
    // handled manually via CUDA_VISIBLE_DEVICES in the script using params.num_gpus.
    cpus = 10          // GPU processes can use more CPU for data prep
    memory = '100 GB'
    maxForks = params.num_gpus  // One organism_id task per GPU; matches CUDA_VISIBLE_DEVICES logic
    time = '6h'        // Timeout for organism identification
    // On timeout or any failure, ignore and continue -- downstream infers taxids from PRIDE + LLM only
    errorStrategy = 'ignore'
    maxRetries = 0     // Don't retry - if it times out once, it will again
  }
  
  withName: parse_runAssessor {
    cpus = 4
    memory = '8 GB'
    time = '30m'       // Timeout for parameter detection
    errorStrategy = 'ignore'
  }
  
  withName: search {
    cpus = 16          // Reduced from 16 - single-threaded per-file searches (OMP_NUM_THREADS=1)
    memory = '75 GB' // Reduced from 600 GB - each per-file search uses ~30-60 GB max
    maxForks = 4      // Parallel processing - only 1 search at a time
    time = '12h'      // Timeout - large PXDs can exceed 4 hours
  }
  
  withName: aggregate_results {
    cpus = 2          // Light processing - mainly I/O and JSON manipulation
    memory = '4 GB'   // Should be sufficient for combining results
    maxForks = 10     // Can run multiple aggregations in parallel
    errorStrategy = 'ignore'  // Skip PXDs that fail aggregation
  }
  
  withName: llm_extraction {
    cpus = 2          // Light processing - API calls are rate-limited
    memory = '8 GB'   // Memory for loading publication text
    maxForks = 3      // Limit parallel API calls to avoid rate limits
  }
  
  withName: determine_taxids {
    cpus = 2          // Light processing - JSON parsing and comparison
    memory = '4 GB'   // Should be sufficient for metadata parsing
    maxForks = 10     // Can run multiple in parallel
  }
}

// Enable resume by default
resume = true

// Singularity disabled - using conda environments for all tools

// Conda configuration - use pre-existing environments without creating new ones
conda {
  enabled = true
  // useMamba = false - use conda (not mamba)
  // cacheDir - not set, use default
  // createOptions - not set to prevent auto-creation
  // createTimeout - not set
}
